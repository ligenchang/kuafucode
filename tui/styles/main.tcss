/* nvagent — Claude Code-style theme */

Screen {
    background: #0d1117;
    color: #e6edf3;
}

/* ── Outer shell ────────────────────────────────────────────────────────── */

#outer {
    width: 100%;
    height: 100%;
}

/* ── Chat log ──────────────────────────────────────────────────────────── */

#chat-log {
    background: #0d1117;
    color: #e6edf3;
    padding: 1 4;
    height: 1fr;
    scrollbar-color: #2a2a2a;
    scrollbar-background: #0d1117;
    overflow-y: auto;
}

/* ── Input row ─────────────────────────────────────────────────────────── */

#input-row {
    height: 3;
    background: #0d1117;
    border-top: solid #1e1e1e;
    padding: 0 2;
    align: left middle;
}

#prompt-sym {
    color: #76b900;
    text-style: bold;
    width: 3;
    height: 3;
    content-align: left middle;
    padding: 0 1 0 0;
}

#user-input {
    background: #0d1117;
    color: #e6edf3;
    border: none;
    height: 3;
    padding: 0 1;
    width: 1fr;
}

#user-input:focus {
    border: none;
    background: #0d1117;
}

/* ── Status bar ────────────────────────────────────────────────────────── */

#status-bar {
    background: #161b22;
    color: #484f58;
    height: 1;
    padding: 0 2;
    border-top: solid #1e1e1e;
    content-align: left middle;
}
